// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Roster {
  id        String   @id @default(uuid())
  employee  String
  shifts    String[] // Stores the morning/evening/off states as an array
  hours     Json     // Stores the exact custom hours for each day
  createdAt DateTime @default(now())
}